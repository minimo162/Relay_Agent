# Task Master and provider integration environment variables
#
# This file is NOT required to run the Relay Agent desktop app from source.
# The desktop app in README works without copying this file.
#
# Use this file only if you want Task Master or provider-backed integrations
# that read API keys from the environment.
#
# Current `.taskmaster/config.json` defaults:
# - main model: anthropic
# - research model: perplexity
# - fallback model: anthropic

ANTHROPIC_API_KEY=""       # Needed only if you want to use the current Task Master main/fallback Anthropic models. Format: sk-ant-api03-...
PERPLEXITY_API_KEY=""      # Needed only if you want to use the current Task Master research model. Format: pplx-...
OPENAI_API_KEY=""          # Optional alternate provider for OpenAI models. Format: sk-proj-...
GOOGLE_API_KEY=""          # Optional alternate provider for Google Gemini models.
MISTRAL_API_KEY=""         # Optional alternate provider for Mistral AI models.
XAI_API_KEY=""             # Optional alternate provider for xAI models.
GROQ_API_KEY=""            # Optional alternate provider for Groq models.
OPENROUTER_API_KEY=""      # Optional alternate provider for OpenRouter models.
AZURE_OPENAI_API_KEY=""    # Optional alternate provider for Azure OpenAI models; also requires the Azure endpoint in `.taskmaster/config.json`.
OLLAMA_API_KEY=""          # Optional only for remote Ollama servers that require authentication.
GITHUB_API_KEY=""          # Optional only for GitHub import/export features. Format: ghp_... or github_pat_...
