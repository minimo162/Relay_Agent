{
  "name": "relay-agent",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "check": "pnpm --filter @relay-agent/desktop check",
    "launch:test": "pnpm --filter @relay-agent/desktop launch:test",
    "workflow:test": "pnpm --filter @relay-agent/desktop workflow:test",
    "typecheck": "pnpm --filter @relay-agent/desktop typecheck",
    "startup:test": "pnpm --filter @relay-agent/desktop startup:test",
    "test:e2e:local": "pnpm --filter @relay-agent/desktop test:e2e:local",
    "dev": "pnpm --filter @relay-agent/desktop dev"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "ws": "^8.20.0"
  }
}
