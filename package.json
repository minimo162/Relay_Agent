{
  "name": "relay-agent",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "check": "pnpm typecheck && pnpm --filter @relay-agent/desktop build",
    "doctor": "cargo run --manifest-path apps/desktop/src-tauri/Cargo.toml --bin relay-agent-doctor --",
    "launch:test": "pnpm --filter @relay-agent/desktop launch:test",
    "agent-loop:test": "pnpm --filter @relay-agent/desktop agent-loop:test",
    "smoke:windows": "pnpm --filter @relay-agent/desktop smoke:windows",
    "live:m365:desktop-smoke": "pnpm --filter @relay-agent/desktop live:m365:desktop-smoke",
    "live:m365:tetris-html": "pnpm --filter @relay-agent/desktop live:m365:tetris-html",
    "live:m365:grounding-approval-multiturn": "pnpm --filter @relay-agent/desktop live:m365:grounding-approval-multiturn",
    "live:m365:path-resolution-same-session": "pnpm --filter @relay-agent/desktop live:m365:path-resolution-same-session",
    "live:m365:workspace-search": "pnpm --filter @relay-agent/desktop live:m365:workspace-search",
    "typecheck": "pnpm --filter @relay-agent/desktop typecheck",
    "test:e2e:local": "pnpm --filter @relay-agent/desktop test:e2e:local",
    "test:e2e:auth-save": "pnpm --filter @relay-agent/desktop test:e2e:auth-save",
    "dev": "pnpm --filter @relay-agent/desktop dev",
    "relay:dev:linux": "bash scripts/relay-copilot-linux.sh",
    "relay:edge": "bash scripts/start-relay-edge-cdp.sh",
    "test:grounding-fixture": "bash scripts/verify-grounding-fixture.sh",
    "test:e2e:copilot-grounding": "pnpm --filter @relay-agent/desktop test:e2e:copilot-grounding",
    "test:e2e:m365-cdp": "pnpm --filter @relay-agent/desktop test:e2e:m365-cdp"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "ws": "^8.20.0"
  }
}
