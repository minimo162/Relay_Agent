{
  "name": "relay-agent",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "check": "node scripts/check-hard-cut-guard.mjs && pnpm check:opencode-provider && pnpm typecheck && pnpm --filter @relay-agent/desktop build",
    "bootstrap:openwork-opencode": "cargo run --manifest-path apps/desktop/src-tauri/Cargo.toml --bin relay-openwork-bootstrap",
    "bootstrap:openwork-opencode:auto": "cargo run --manifest-path apps/desktop/src-tauri/Cargo.toml --bin relay-openwork-bootstrap -- --auto --pretty",
    "start:opencode-provider-gateway": "pnpm --filter @relay-agent/desktop start:opencode-provider-gateway",
    "install:opencode-provider-config": "pnpm --filter @relay-agent/desktop install:opencode-provider-config",
    "check:opencode-provider": "pnpm --filter @relay-agent/desktop check:opencode-provider",
    "smoke:opencode-provider": "pnpm --filter @relay-agent/desktop smoke:opencode-provider",
    "smoke:opencode-bootstrap-config": "pnpm --filter @relay-agent/desktop smoke:opencode-bootstrap-config",
    "smoke:openwork-desktop-handoff": "pnpm --filter @relay-agent/desktop smoke:openwork-desktop-handoff",
    "smoke:openwork-opencode-bootstrap-auto": "pnpm --filter @relay-agent/desktop smoke:openwork-opencode-bootstrap-auto",
    "smoke:openwork-opencode-bootstrap-headless": "pnpm --filter @relay-agent/desktop smoke:openwork-opencode-bootstrap-headless",
    "smoke:openwork-opencode-bootstrap-gateway": "pnpm --filter @relay-agent/desktop smoke:openwork-opencode-bootstrap-gateway",
    "live:windows:openwork-bootstrap": "pnpm --filter @relay-agent/desktop live:windows:openwork-bootstrap",
    "live:m365:opencode-provider": "pnpm --filter @relay-agent/desktop live:m365:opencode-provider",
    "doctor": "cargo run --manifest-path apps/desktop/src-tauri/Cargo.toml --bin relay-agent-doctor --",
    "diag:desktop-launch": "pnpm --filter @relay-agent/desktop diag:desktop-launch",
    "diag:windows-smoke": "pnpm --filter @relay-agent/desktop diag:windows-smoke",
    "typecheck": "pnpm --filter @relay-agent/desktop typecheck",
    "test:e2e:local": "pnpm --filter @relay-agent/desktop test:e2e:local",
    "test:e2e:auth-save": "pnpm --filter @relay-agent/desktop test:e2e:auth-save",
    "dev": "pnpm bootstrap:openwork-opencode:auto",
    "diag:frontend": "pnpm --filter @relay-agent/desktop diag:frontend",
    "diag:tauri-dev": "pnpm --filter @relay-agent/desktop diag:tauri-dev",
    "diag:tauri-dev:cdp": "pnpm --filter @relay-agent/desktop diag:tauri-dev:cdp",
    "relay:dev:linux": "bash scripts/relay-copilot-linux.sh",
    "relay:edge": "bash scripts/start-relay-edge-cdp.sh",
    "test:grounding-fixture": "bash scripts/verify-grounding-fixture.sh",
    "test:e2e:copilot-grounding": "pnpm --filter @relay-agent/desktop test:e2e:copilot-grounding",
    "test:e2e:m365-cdp": "pnpm --filter @relay-agent/desktop test:e2e:m365-cdp"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "ws": "^8.20.0"
  }
}
