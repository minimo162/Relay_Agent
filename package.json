{
  "name": "relay-agent",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "check": "node scripts/check-hard-cut-guard.mjs && pnpm typecheck && pnpm build && pnpm sidecar:build && pnpm sidecar:smoke && pnpm sidecar:app-server-artifact-smoke && pnpm sidecar:app-server-bridge-smoke && pnpm sidecar:app-server-real-provider-smoke && pnpm sidecar:responses-schema-validation-smoke && pnpm sidecar:idle-exit-smoke && pnpm sidecar:copilot-cdp-smoke && pnpm sidecar:workspace-picker-smoke && pnpm release:icon-smoke && pnpm release:portable-root-smoke && pnpm workbench:bridge-surface-smoke && pnpm workbench:bridge-chat-smoke && pnpm sidecar:security-smoke && pnpm release:inventory",
    "build": "pnpm --filter @relay-agent/workbench build && node scripts/prepare-sidecar-assets.mjs",
    "dev": "pnpm build && dotnet run --project apps/sidecar/Relay.Sidecar.csproj",
    "sidecar:build": "dotnet build apps/sidecar/Relay.Sidecar.csproj --configuration Release",
    "sidecar:smoke": "node scripts/sidecar-smoke.mjs",
    "sidecar:app-server-artifact-smoke": "node scripts/app-server-artifact-smoke.mjs",
    "sidecar:app-server-bridge-smoke": "node scripts/app-server-bridge-smoke.mjs",
    "sidecar:app-server-real-provider-smoke": "node scripts/app-server-real-provider-smoke.mjs",
    "sidecar:responses-schema-validation-smoke": "node scripts/responses-schema-validation-smoke.mjs",
    "sidecar:idle-exit-smoke": "node scripts/sidecar-idle-exit-smoke.mjs",
    "sidecar:copilot-cdp-smoke": "node scripts/copilot-cdp-manager-smoke.mjs",
    "sidecar:security-smoke": "node scripts/sidecar-security-smoke.mjs",
    "sidecar:workspace-picker-smoke": "node scripts/workspace-picker-smoke.mjs",
    "workbench:ux-e2e": "pnpm build && pnpm sidecar:build && node scripts/workbench-ux-e2e.mjs",
    "workbench:live-copilot-e2e": "pnpm build && pnpm sidecar:build && node scripts/workbench-live-copilot-e2e.mjs",
    "workbench:bridge-surface-smoke": "node scripts/bridge-workbench-surface-smoke.mjs",
    "workbench:bridge-chat-smoke": "node scripts/bridge-workbench-chat-smoke.mjs",
    "appserver:fetch:linux": "node scripts/release/fetch-codex-app-server.mjs --rid linux-x64",
    "appserver:fetch:windows": "node scripts/release/fetch-codex-app-server.mjs --rid win-x64",
    "sidecar:publish:linux": "pnpm build && pnpm appserver:fetch:linux && node scripts/release/package-sidecar.mjs --rid linux-x64",
    "sidecar:publish:windows": "pnpm build && pnpm appserver:fetch:windows && node scripts/release/package-sidecar.mjs --rid win-x64",
    "sidecar:archive:linux": "node scripts/release/archive-sidecar.mjs --rid linux-x64",
    "sidecar:archive:windows": "node scripts/release/archive-sidecar.mjs --rid win-x64",
    "sidecar:portable:linux": "pnpm sidecar:publish:linux && pnpm sidecar:archive:linux",
    "sidecar:portable:windows": "pnpm sidecar:publish:windows && pnpm sidecar:archive:windows",
    "sidecar:installer:windows": "node scripts/release/build-windows-installer.mjs --rid win-x64",
    "release:inventory": "node scripts/release/collect-inventory.mjs",
    "release:icon-smoke": "node scripts/release/icon-packaging-smoke.mjs",
    "release:portable-root-smoke": "node scripts/release/portable-root-smoke.mjs",
    "typecheck": "pnpm --filter @relay-agent/workbench typecheck",
    "relay:dev:linux": "bash scripts/relay-copilot-linux.sh",
    "relay:edge": "bash scripts/start-relay-edge-cdp.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "ws": "^8.20.0"
  }
}
