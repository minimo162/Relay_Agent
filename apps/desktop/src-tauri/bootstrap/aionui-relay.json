      "version": "1.9.25",
      "tag": "v1.9.25",
      "commit": "bbada2a9268060d2b41ddf1d885a9b27ecd2103d",
      "license": "Apache-2.0",
      "integrationMode": "relay-branded-fork-or-wrapper",
      "notes": [
        "AionUi is the source baseline for the Relay Agent product UX.",
        "Relay must replace app name, icons, protocol, installer metadata, update metadata, and first-run provider defaults before distribution.",
        "Relay must not ship upstream remote/channel/provider onboarding defaults as beginner-facing product flow."
      ]
    },
    "officeCli": {
      "name": "OfficeCLI",
      "repository": "https://github.com/iOfficeAI/OfficeCLI",
      "version": "1.0.76",
      "tag": "v1.0.76",
      "commit": "958717ea25351b8920a3d8313d46e08b24b9c95b",
      "license": "Apache-2.0",
      "installMode": "relay-managed-portable-user-local",
      "artifacts": {
        "windows-x64": {
          "name": "officecli-win-x64.exe",
          "kind": "binary",
          "format": "exe",
          "url": "https://github.com/iOfficeAI/OfficeCLI/releases/download/v1.0.76/officecli-win-x64.exe",
          "sha256": "f9e4895505858ab813e133d4d1f9f01004c7b4b08397408487f534caf9e2ec58",
          "size": 30433916,
          "entrypoint": "officecli.exe"
        }
      },
      "notes": [
        "Relay stores OfficeCLI under app-local data and prepends that directory to the AionUi child-process PATH.",
        "Relay does not use the upstream PowerShell or shell install scripts in the product first-run path.",
        "The SHA256 value is cross-checked against the upstream OfficeCLI v1.0.76 SHA256SUMS release asset."
      ]
    }
  },
