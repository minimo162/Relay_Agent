{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Relay Agent",
  "version": "0.2.10",
  "identifier": "com.relayagent.desktop",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Relay Agent",
        "width": 1280,
        "height": 840,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/relay-node", "binaries/relay-rg"],
    "resources": {
      "../../../examples/revenue-workflow-demo.csv": "examples/revenue-workflow-demo.csv",
      "binaries/copilot_dom_poll.mjs": "binaries/copilot_dom_poll.mjs",
      "binaries/copilot_send_timing.mjs": "binaries/copilot_send_timing.mjs",
      "binaries/copilot_server.js": "binaries/copilot_server.js",
      "binaries/copilot_server.mjs": "binaries/copilot_server.mjs",
      "binaries/copilot_wait_dom_response.mjs": "binaries/copilot_wait_dom_response.mjs",
      "binaries/relay-officecli-win-x64.exe": "relay-tools/officecli/officecli.exe",
      "resources/relay-document-search/": "relay-document-search/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
