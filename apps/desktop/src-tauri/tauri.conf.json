{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Relay Agent",
  "version": "0.1.0",
  "identifier": "com.relayagent.desktop",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Relay Agent",
        "width": 1280,
        "height": 840
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../../examples/revenue-workflow-demo.csv": "examples/revenue-workflow-demo.csv"
    },
    "icon": ["icons/icon.png"]
  }
}
