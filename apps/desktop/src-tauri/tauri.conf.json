{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Relay Agent",
  "version": "0.1.0",
  "identifier": "com.relayagent.desktop",
  "build": {
    "beforeBuildCommand": "node ./scripts/fetch-bundled-node.mjs && npm ci --omit=dev --prefix ./src-tauri/liteparse-runner && pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Relay Agent",
        "width": 1280,
        "height": 840
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/relay-node"],
    "resources": {
      "../../../examples/revenue-workflow-demo.csv": "examples/revenue-workflow-demo.csv",
      "liteparse-runner/": "liteparse-runner/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
