# Copy to `.env.e2e` (gitignored) in this directory. Used by Playwright (load-e2e-env).

# Microsoft consumer / M365 sign-in for Copilot web (globalSetup refreshes storage state).
M365_COPILOT_EMAIL=
M365_COPILOT_PASSWORD=

# Optional: open this URL instead of Copilot when starting sign-in (copy from browser address bar).
# E2E_MICROSOFT_LOGIN_URL=https://login.microsoftonline.com/...

# Optional: override consumer login fallback (default tries login.live.com then account.live.com).
# E2E_LOGIN_LIVE_FALLBACK_URL=https://login.live.com/

# Optional: base32 TOTP secret for automated MFA (same as authenticator app backup).
# M365_COPILOT_TOTP_SECRET=

# Skip browser auth in globalSetup (local UI tests only).
# E2E_SKIP_AUTH_SETUP=1

# Reuse saved storage while younger than N hours (default 24).
# E2E_AUTH_MAX_AGE_HOURS=24

# Force new login even if storage state exists (does not load prior storageState).
# E2E_FORCE_AUTH=1

# Stale auth JSON is still loaded once: if Copilot is already signed in, the script skips email/password and only refreshes storage.

# Show browser during sign-in; also enables periodic 2FA screenshots when combined with E2E_2FA_SCREENSHOTS=1.
# On Linux over SSH, set DISPLAY (e.g. :0) or use: xvfb-run -a pnpm test:e2e
# E2E_HEADED=1

# Max wait (ms) after password for push approval / manual 2FA (default 300000).
# E2E_POST_PASSWORD_TIMEOUT_MS=300000

# Minimum post-password wait budget (ms); max of this and E2E_POST_PASSWORD_TIMEOUT_MS is used.
# E2E_2FA_PAUSE_MS=600000

# While waiting, write full-page screenshots under test-results/ every N ms (headed or E2E_2FA_SCREENSHOTS=1).
# E2E_2FA_SCREENSHOT_INTERVAL_MS=30000

# Take 2FA wait screenshots even in headless mode.
# E2E_2FA_SCREENSHOTS=1

# When this file appears (e.g. `touch .e2e-auth-done` from repo root), continue waiting for Copilot URL.
# E2E_2FA_WAIT_FILE=.e2e-auth-done

# Optional: use system Chrome channel for globalSetup (e.g. chrome, msedge).
# E2E_CHROME_CHANNEL=chrome

# Microsoft Authenticator の「番号照合」で表示される2桁を、ターミナルと次のファイルに書き出す（既定）。
# E2E_MATCH_NUMBER_OUT=my-approve-number.txt
