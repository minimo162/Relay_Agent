{
  "name": "@relay-agent/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "pnpm typecheck && pnpm build",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prep:bundled-node": "node ./scripts/fetch-bundled-node.mjs",
    "prep:bundled-ripgrep": "node ./scripts/fetch-bundled-ripgrep.mjs",
    "prep:liteparse-runner": "npm ci --omit=dev --prefix ./src-tauri/liteparse-runner",
    "prep:tauri-bundle": "pnpm run prep:bundled-node && pnpm run prep:bundled-ripgrep && pnpm run prep:liteparse-runner",
    "tauri:dev": "node ./scripts/prestart-relay-edge.mjs && tauri dev",
    "tauri:dev:approve": "node ./scripts/dev-approve-latest.mjs",
    "tauri:dev:approve:session": "node ./scripts/dev-approve-latest-session.mjs",
    "tauri:dev:approve:workspace": "node ./scripts/dev-approve-latest-workspace.mjs",
    "tauri:dev:reject": "node ./scripts/dev-reject-latest.mjs",
    "tauri:dev:send": "node ./scripts/dev-first-run-send.mjs",
    "tauri:dev:cdp": "node ./scripts/tauri-dev-cdp.mjs",
    "tauri:build": "pnpm run prep:tauri-bundle && tauri build",
    "start:opencode-provider-gateway": "node ./scripts/start_opencode_provider_gateway.mjs",
    "install:opencode-provider-config": "node ./scripts/install_opencode_provider_config.mjs",
    "check:opencode-provider": "node --check ./scripts/opencode_provider_config.mjs && node --check ./scripts/install_opencode_provider_config.mjs && node --check ./scripts/start_opencode_provider_gateway.mjs && node --check ./scripts/opencode_provider_gateway_smoke.mjs && node --check ./scripts/live_m365_opencode_provider_smoke.mjs && node --test ./src-tauri/binaries/copilot_server.test.mjs",
    "smoke:opencode-provider": "node ./scripts/opencode_provider_gateway_smoke.mjs",
    "live:m365:opencode-provider": "node ./scripts/live_m365_opencode_provider_smoke.mjs",
    "diag:desktop-launch": "node ./scripts/launch_tauri_smoke.mjs",
    "diag:windows-smoke": "node ./scripts/e2e_windows_smoke.mjs",
    "diag:m365:desktop-smoke": "node ./scripts/live_m365_desktop_smoke.mjs",
    "diag:m365:tetris-html": "node ./scripts/live_m365_tetris_html_smoke.mjs",
    "diag:m365:grounding-approval-multiturn": "node ./scripts/live_m365_multiturn_grounding_approval.mjs",
    "diag:m365:path-resolution-same-session": "node ./scripts/live_m365_same_session_path_resolution.mjs",
    "diag:m365:workspace-search": "node ./scripts/live_m365_workspace_search_smoke.mjs",
    "diag:m365:long-continuity": "node ./scripts/live_m365_long_continuity_smoke.mjs",
    "diag:m365:heterogeneous-tools": "node ./scripts/live_m365_heterogeneous_tools_smoke.mjs",
    "live:m365:copilot-response-probe": "node ./scripts/live_m365_copilot_response_probe.mjs",
    "test:e2e": "playwright test",
    "test:e2e:m365-cdp": "playwright test --config=playwright-cdp.config.ts --project=m365-cdp-chat",
    "test:e2e:copilot-grounding": "RELAY_GROUNDING_E2E=1 playwright test --config=playwright-cdp.config.ts -g tetris",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:local": "E2E_SKIP_AUTH_SETUP=1 playwright test app.e2e.spec.ts",
    "test:e2e:auth-save": "E2E_AUTH_SAVE_RUN=1 playwright test -c playwright.auth-save.config.ts",
    "test:e2e:webview-cdp": "playwright test -c playwright.webview-cdp.config.ts",
    "test:e2e:agent-browser": "node ./scripts/e2e-agent-browser.mjs",
    "test:e2e:agent-browser:with-app": "node ./scripts/e2e-agent-browser.mjs --with-app",
    "test:e2e:agent-browser:with-app:keep": "node ./scripts/e2e-agent-browser.mjs --with-app --keep-app",
    "test:e2e:agent-browser:with-app:demo": "node ./scripts/e2e-agent-browser.mjs --with-app --keep-app --ui-demo",
    "inspect:copilot-dom": "node ./scripts/inspect-copilot-dom.mjs"
  },
  "dependencies": {
    "@solidjs/router": "0.15.4",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "dompurify": "^3.3.3",
    "marked": "^18.0.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^24.5.2",
    "otplib": "^13.4.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0"
  }
}
