{
  "name": "@relay-agent/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "pnpm typecheck && pnpm build",
    "dev": "vite",
    "diag:frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prep:bundled-node": "node ./scripts/fetch-bundled-node.mjs",
    "prep:bundled-ripgrep": "node ./scripts/fetch-bundled-ripgrep.mjs",
    "prep:liteparse-runner": "npm ci --omit=dev --prefix ./src-tauri/liteparse-runner",
    "prep:tauri-bundle": "pnpm run prep:bundled-node && pnpm run prep:bundled-ripgrep && pnpm run prep:liteparse-runner",
    "diag:tauri-dev": "node ./scripts/prestart-relay-edge.mjs && tauri dev",
    "diag:tauri-dev:cdp": "node ./scripts/tauri-dev-cdp.mjs",
    "tauri:build": "pnpm run prep:tauri-bundle && tauri build",
    "bootstrap:openwork-opencode": "cargo run --manifest-path ./src-tauri/Cargo.toml --bin relay-openwork-bootstrap",
    "start:opencode-provider-gateway": "node ./scripts/start_opencode_provider_gateway.mjs",
    "install:opencode-provider-config": "node ./scripts/install_opencode_provider_config.mjs",
    "check:opencode-provider": "node --check ./scripts/opencode_provider_config.mjs && node --check ./scripts/install_opencode_provider_config.mjs && node --check ./scripts/start_opencode_provider_gateway.mjs && node --check ./scripts/opencode_provider_gateway_smoke.mjs && node --check ./scripts/live_m365_opencode_provider_smoke.mjs && node --check ./scripts/opencode_cli_bootstrap_config_smoke.mjs && node --check ./scripts/openwork_desktop_handoff_smoke.mjs && node --check ./scripts/live_windows_openwork_opencode_bootstrap_smoke.mjs && node --check ./scripts/openwork_opencode_headless_bootstrap_smoke.mjs && node --check ./scripts/openwork_opencode_provider_gateway_bootstrap_smoke.mjs && node --test ./scripts/openwork_opencode_bootstrap_manifest.test.mjs && node --test ./src-tauri/binaries/copilot_server.test.mjs",
    "smoke:opencode-bootstrap-config": "node ./scripts/opencode_cli_bootstrap_config_smoke.mjs",
    "smoke:openwork-desktop-handoff": "node ./scripts/openwork_desktop_handoff_smoke.mjs",
    "smoke:openwork-opencode-bootstrap-headless": "node ./scripts/openwork_opencode_headless_bootstrap_smoke.mjs",
    "smoke:openwork-opencode-bootstrap-gateway": "node ./scripts/openwork_opencode_provider_gateway_bootstrap_smoke.mjs",
    "live:windows:openwork-bootstrap": "node ./scripts/live_windows_openwork_opencode_bootstrap_smoke.mjs",
    "smoke:opencode-provider": "node ./scripts/opencode_provider_gateway_smoke.mjs",
    "live:m365:opencode-provider": "node ./scripts/live_m365_opencode_provider_smoke.mjs",
    "diag:desktop-launch": "node ./scripts/launch_tauri_smoke.mjs",
    "diag:windows-smoke": "node ./scripts/e2e_windows_smoke.mjs",
    "live:m365:copilot-response-probe": "node ./scripts/live_m365_copilot_response_probe.mjs",
    "test:e2e": "playwright test",
    "test:e2e:m365-cdp": "playwright test --config=playwright-cdp.config.ts --project=m365-cdp-chat",
    "test:e2e:copilot-grounding": "RELAY_GROUNDING_E2E=1 playwright test --config=playwright-cdp.config.ts -g tetris",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:local": "E2E_SKIP_AUTH_SETUP=1 playwright test app.e2e.spec.ts",
    "test:e2e:auth-save": "E2E_AUTH_SAVE_RUN=1 playwright test -c playwright.auth-save.config.ts",
    "test:e2e:webview-cdp": "playwright test -c playwright.webview-cdp.config.ts",
    "test:e2e:agent-browser": "node ./scripts/e2e-agent-browser.mjs",
    "test:e2e:agent-browser:with-app": "node ./scripts/e2e-agent-browser.mjs --with-app",
    "test:e2e:agent-browser:with-app:keep": "node ./scripts/e2e-agent-browser.mjs --with-app --keep-app",
    "test:e2e:agent-browser:with-app:demo": "node ./scripts/e2e-agent-browser.mjs --with-app --keep-app --ui-demo",
    "inspect:copilot-dom": "node ./scripts/inspect-copilot-dom.mjs"
  },
  "dependencies": {
    "@solidjs/router": "0.15.4",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "dompurify": "^3.3.3",
    "marked": "^18.0.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^24.5.2",
    "otplib": "^13.4.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0"
  }
}
