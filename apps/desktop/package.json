{
  "name": "@relay-agent/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 1421",
    "build": "svelte-kit sync && vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "copilot-browser:build": "npx esbuild scripts/copilot-browser.ts --bundle --platform=node --format=esm --packages=external --outfile=scripts/dist/copilot-browser.js",
    "launch:test": "node ./scripts/launch_tauri_smoke.mjs",
    "workflow:test": "node ./scripts/launch_workflow_smoke.mjs",
    "startup:smoke": "cargo run --manifest-path src-tauri/Cargo.toml --bin startup_smoke",
    "startup:test": "cargo run --manifest-path src-tauri/Cargo.toml --bin startup_smoke && cargo test --manifest-path src-tauri/Cargo.toml startup::tests",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@relay-agent/contracts": "workspace:*",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.3.5"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^24.5.2",
    "playwright": "^1.58.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.9.3",
    "esbuild": "^0.25.0",
    "vite": "^6.0.0"
  }
}
